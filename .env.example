# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase 대시보드 > Project Settings > API Keys > secret key (sb_secret_...)
# 주의: NEXT_PUBLIC_ 접두사를 붙이면 브라우저 번들에 노출되어 DB 전체가 열립니다.
SUPABASE_SECRET_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.6-sol
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# 로그인 쿠키 서명용 키: openssl rand -base64 32
SESSION_SECRET=
OPENAI_IMAGE_MODEL=gpt-image-2
